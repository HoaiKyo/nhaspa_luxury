# Database - SQL Server
DB_DRIVER=ODBC Driver 17 for SQL Server
DB_HOST=localhost
DB_PORT=1433
DB_NAME=spa_db
DB_USER=sa
DB_PASSWORD=Admin@123456

# JWT
JWT_SECRET_KEY=dev-secret-key-change-in-production-abc123xyz
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# App
APP_NAME=Nhà Spa Management System
APP_VERSION=1.0.0
APP_DEBUG=true

ACCEPT_EULA=Y
MSSQL_SA_PASSWORD=Admin@123456
MSSQL_PID=Developer